{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies"],
  "rangeStrategy": "pin",
  "schedule": ["before 6am on Monday"],
  "packageRules": [
    {
      "matchDepTypes": ["devDependencies"],
      "groupName": "dev-tooling",
      "matchPackageNames": [
        "@eslint/js",
        "@types/*",
        "@typescript-eslint/*",
        "eslint",
        "globals",
        "jest",
        "jest-junit",
        "prettier",
        "ts-jest",
        "ts-node",
        "typescript"
      ]
    },
    {
      "matchPackageNames": ["@modelcontextprotocol/sdk", "better-sqlite3", "simple-statistics", "ssh2"],
      "automerge": false
    }
  ]
}
