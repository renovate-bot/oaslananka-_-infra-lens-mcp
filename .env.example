# mcp-infra-lens environment variables
# Copy to .env for local development. Never commit .env.

# Transport
MCP_TRANSPORT=stdio
MCP_PROFILE=full

# HTTP transport
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3000
MCP_HTTP_ALLOWED_ORIGINS=
MCP_HTTP_ALLOWED_HOSTS=
MCP_HTTP_AUTH_MODE=none
MCP_HTTP_BEARER_TOKEN=
MCP_HTTP_BODY_LIMIT_BYTES=1048576
MCP_HTTP_AUTHORIZATION_SERVERS=
MCP_HTTP_RESOURCE_URL=

# Storage
INFRA_LENS_DB=~/.mcp-infra-lens/metrics.db

# SSH
MCP_SSH_STRICT_HOST_CHECKING=true
MCP_SSH_KNOWN_HOSTS=~/.ssh/known_hosts
MCP_SSH_ALLOWED_HOSTS=

# Optional tracing
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=mcp-infra-lens
